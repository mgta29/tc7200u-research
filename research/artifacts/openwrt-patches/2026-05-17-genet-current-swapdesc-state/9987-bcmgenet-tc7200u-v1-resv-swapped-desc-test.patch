@@ -2037,6 +2037,10 @@
 #define TC7200U_RESV_TX_SIZE 0x00001000
 static void __iomem *tc7200u_resv_tx_virt;
 
+#define TC7200U_RESV_TX_PHYS ((phys_addr_t)0x01680000)
+#define TC7200U_RESV_TX_SIZE 0x00001000
+static void __iomem *tc7200u_resv_tx_virt;
+
 static netdev_tx_t bcmgenet_xmit(struct sk_buff *skb, struct net_device *dev)
 {
 	struct bcmgenet_priv *priv = netdev_priv(dev);
