+					    tc7200u_resv_tx_virt,
+					    TC7200U_RESV_TX_SIZE);
+			}
+
+			if (tc7200u_resv_tx_virt) {
+				memcpy_toio(tc7200u_resv_tx_virt, skb->data, size);
+				wmb();
+
+				mapping = tc7200u_resv_dma;
+
+				/* Diagnostic only: test swapped GENET v1 descriptor word order. */
