+
+				rb0 = __raw_readl(bd + DMA_DESC_LENGTH_STATUS);
+				rb4 = __raw_readl(bd + DMA_DESC_ADDRESS_LO);
+
+				netdev_info(dev,
+					    "TC7200U SWAPDESC i=%d size=%u virt=%px dma=%pad low20=0x%05x len_stat=0x%08x rb0=0x%08x rb4=0x%08x bd_addr=%px\n",
