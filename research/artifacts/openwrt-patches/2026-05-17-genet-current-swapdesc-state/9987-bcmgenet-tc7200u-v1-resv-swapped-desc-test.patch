+					    len_stat, rb0, rb4, bd);
+			} else {
+				netdev_info(dev, "TC7200U SWAPDESC no ioremap buffer\n");
+				dmadesc_set(priv, tx_cb_ptr->bd_addr, mapping, len_stat);
+			}
+		} else {
+			dmadesc_set(priv, tx_cb_ptr->bd_addr, mapping, len_stat);
+		}
 
